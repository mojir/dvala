{
  "name": "@mojir/dvala-types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared Dvala type vocabulary (AST, values, tokens, constants) \u2014 dependency-free leaf",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rolldown -c ./rolldown.config.mjs && tsgo -p ./tsconfig.json --emitDeclarationOnly",
    "typecheck": "tsgo -p ./tsconfig.json --noEmit"
  }
}
