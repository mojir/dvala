{
  "name": "@mojir/dvala-cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "CLI subproject scaffold for Dvala",
  "//": "Asymmetric build: plain tsgo (no rolldown). This package is a final-binary tail node — the root rolldown.config.cli.mjs bundles it after typecheck. See .github/AGENTS.md > Build conventions.",
  "scripts": {
    "build": "tsgo -p ./tsconfig.json",
    "typecheck": "tsgo -p ./tsconfig.json --noEmit",
    "bundle": "rolldown -c ./rolldown.bundle.config.mjs && chmod +x ./dist/cli.cjs",
    "start": "node ./dist/cli.cjs"
  },
  "dependencies": {
    "@mojir/dvala-common": "workspace:*",
    "@mojir/dvala-core-tooling": "workspace:*",
    "@mojir/dvala-runtime": "workspace:*",
    "@mojir/dvala-test-framework": "workspace:*",
    "@mojir/dvala-workspace-backend": "workspace:*"
  }
}
