{
  "name": "@mojir/dvala-core-tooling",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Tokenizer, parser, CST, formatter, typechecker, language service, and tooling primitives — TS-only, host-independent.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo -p ./tsconfig.json",
    "typecheck": "tsgo -p ./tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mojir/dvala-engine": "workspace:*",
    "@mojir/dvala-types": "workspace:*",
    "@mojir/dvala-runtime": "workspace:*"
  }
}
