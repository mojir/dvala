{
  "name": "@mojir/dvala-core-tooling",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Tokenizer, parser, CST, formatter, typechecker, language service, and tooling primitives — TS-only, host-independent.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/languageService/nodeWorkspaceIndexer.d.ts",
      "import": "./dist/node.js"
    },
    "./bundler": {
      "types": "./dist/bundler/index.d.ts",
      "import": "./dist/bundler/index.js"
    },
    "./reference": {
      "types": "./dist/reference/index.d.ts",
      "import": "./dist/reference/index.js"
    },
    "./reference/api": {
      "types": "./dist/reference/api.d.ts",
      "import": "./dist/reference/api.js"
    },
    "./reference/book": {
      "types": "./dist/reference/book.d.ts",
      "import": "./dist/reference/book.js"
    },
    "./reference/datatype": {
      "types": "./dist/reference/datatype.d.ts",
      "import": "./dist/reference/datatype.js"
    },
    "./reference/examples": {
      "types": "./dist/reference/examples.d.ts",
      "import": "./dist/reference/examples.js"
    },
    "./reference/format": {
      "types": "./dist/reference/format.d.ts",
      "import": "./dist/reference/format.js"
    }
  },
  "scripts": {
    "build": "rolldown -c ./rolldown.config.mjs && tsgo -p ./tsconfig.json --emitDeclarationOnly",
    "typecheck": "tsgo -p ./tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mojir/dvala-engine": "workspace:*",
    "@mojir/dvala-runtime": "workspace:*",
    "@mojir/dvala-types": "workspace:*"
  }
}
