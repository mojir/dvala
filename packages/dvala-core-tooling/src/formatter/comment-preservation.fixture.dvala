/* 2128 */
// --- Unary minus ---
/* 2129 */
let /* 2130 */ neg /* 2131 */ = /* 2132 */ -num;
/* 2133 */
// --- Collect all results as array ---
/* 2134 */
[
/* 2135 */
num,
/* 2136 */
