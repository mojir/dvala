// --- Collection accessors ---
do // Access object properies with .
/* 0 */
// Access string and array elements with []
/* 1 */
let /* 2 */ data /* 3 */ = /* 4 */ { /* 5 */ numbers: /* 6 */ [1, /* 7 */ 2, /* 8 */ 3], /* 9 */ chars: /* 10 */ ["a", /* 11 */ "b", /* 12 */ "c"], /* 13 */ string: /* 14 */ "Albert" /* 15 */ };
/* 16 */
perform(@dvala.io.print, /* 17 */ data.numbers[0]);
/* 18 */
perform(@dvala.io.print, /* 19 */ data.chars[2]);
/* 20 */
perform(@dvala.io.print, /* 21 */ data.string[0]);
/* 22 */
