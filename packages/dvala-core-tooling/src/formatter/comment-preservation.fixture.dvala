// --- Template strings ---
do // Template strings embed expressions with ${...}
/* 37 */
let /* 38 */ name /* 39 */ = /* 40 */ "Alice";
/* 41 */
let /* 42 */ score /* 43 */ = /* 44 */ 42;
/* 45 */
