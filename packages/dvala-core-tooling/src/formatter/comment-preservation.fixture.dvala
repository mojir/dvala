]; end;

// --- Macro toolkit ---
do // ============================================================
/* 2193 */
// Macro Toolkit — a practical collection of utility macros
/* 2194 */
// ============================================================
/* 2195 */
// This example builds a reusable macro toolkit step by step,
/* 2196 */
// showing how macros can generate code, inspect AST, enforce
/* 2197 */
// contracts, and create new control flow constructs.
/* 2198 */
let /* 2199 */ { /* 2200 */ prettyPrint, /* 2201 */ call /* 2202 */ } /* 2203 */ = /* 2204 */ import("ast");
/* 2205 */
let /* 2206 */ { /* 2207 */ fallback /* 2208 */ } /* 2209 */ = /* 2210 */ import("effectHandler");
/* 2211 */
let /* 2212 */ print /* 2213 */ = /* 2214 */ -> /* 2215 */ perform(@dvala.io.print, /* 2216 */ $);
/* 2217 */
let /* 2218 */ error /* 2219 */ = /* 2220 */ -> /* 2221 */ perform(@dvala.error, /* 2222 */ { /* 2223 */ message: /* 2224 */ $ /* 2225 */ });
/* 2226 */
// ─── 1. unless ──────────────────────────────────────────────
/* 2227 */
// The inverse of `if`: runs the body when the condition is *false*.
/* 2228 */
// A classic first macro — one line of quote...end block does it all.
/* 2229 */
let /* 2230 */ unless /* 2231 */ =
/* 2232 */
macro(cond, /* 2233 */ body) /* 2234 */ -> /* 2235 */ quote /* 2236 */ if /* 2237 */ ! /* 2238 */ ($^{cond}) /* 2239 */ then /* 2240 */ $^{body} /* 2241 */ else /* 2242 */ null /* 2243 */ end /* 2244 */ end;
/* 2245 */
print("── unless ──");
/* 2246 */
print(unless(false, /* 2247 */ "condition was false → ran!"));
/* 2248 */
print(unless(true, /* 2249 */ "condition was true → skipped"));
/* 2250 */
// ─── 2. dbg — debug-print with source label ────────────────
/* 2251 */
// Prints "<source> => <value>" and returns the value unchanged.
/* 2252 */
// Uses prettyPrint to convert the unevaluated AST back to source.
/* 2253 */
// Invaluable for tracing expressions without altering control flow.
/* 2254 */
let /* 2255 */ dbg /* 2256 */ =
/* 2257 */
macro(ast) /* 2258 */ -> /* 2259 */ do
/* 2260 */
let /* 2261 */ label /* 2262 */ = /* 2263 */ prettyPrint(ast);
/* 2264 */
quote /* 2265 */ do /* 2266 */ let /* 2267 */ val /* 2268 */ = /* 2269 */ $^{ast}; /* 2270 */ perform(@dvala.io.print, /* 2271 */ $^{["Str", /* 2272 */ label /* 2273 */ ++ /* 2274 */ " => ", /* 2275 */ 0]} /* 2276 */ ++ /* 2277 */ str(val)); /* 2278 */ val /* 2279 */ end /* 2280 */ end;
/* 2281 */
end;
/* 2282 */
print("── dbg ──");
/* 2283 */
let /* 2284 */ x /* 2285 */ = /* 2286 */ dbg(3 /* 2287 */ + /* 2288 */ 4);
/* 2289 */
dbg(x /* 2290 */ * /* 2291 */ 2);
/* 2292 */
dbg(map([1, /* 2293 */ 2, /* 2294 */ 3], /* 2295 */ -> /* 2296 */ $ /* 2297 */ ^ /* 2298 */ 2));
/* 2299 */
// ─── 3. assert and assertEq — test assertions ──────────────
/* 2300 */
// assert(cond) — fails with the source expression on false
/* 2301 */
// assertEq(actual, expected) — fails with both values on mismatch
/* 2302 */
//
/* 2303 */
// The macros capture the source text at compile time via prettyPrint,
/* 2304 */
// so error messages are automatically descriptive.
/* 2305 */
let /* 2306 */ assert /* 2307 */ =
/* 2308 */
macro(cond) /* 2309 */ -> /* 2310 */ do
/* 2311 */
let /* 2312 */ src /* 2313 */ = /* 2314 */ prettyPrint(cond);
/* 2315 */
quote /* 2316 */ do /* 2317 */ let /* 2318 */ v /* 2319 */ = /* 2320 */ $^{cond}; /* 2321 */ if /* 2322 */ ! /* 2323 */ (v) /* 2324 */ then /* 2325 */ error("Assertion failed: " /* 2326 */ ++ /* 2327 */ $^{["Str", /* 2328 */ src, /* 2329 */ 0]}) /* 2330 */ else /* 2331 */ true /* 2332 */ end /* 2333 */ end /* 2334 */ end;
/* 2335 */
end;
/* 2336 */
let /* 2337 */ assertEq /* 2338 */ =
/* 2339 */
macro(actual, /* 2340 */ expected) /* 2341 */ -> /* 2342 */ do
/* 2343 */
let /* 2344 */ actualSrc /* 2345 */ = /* 2346 */ prettyPrint(actual);
/* 2347 */
quote /* 2348 */ do /* 2349 */ let /* 2350 */ a /* 2351 */ = /* 2352 */ $^{actual}; /* 2353 */ let /* 2354 */ e /* 2355 */ = /* 2356 */ $^{expected}; /* 2357 */ if /* 2358 */ a /* 2359 */ != /* 2360 */ e /* 2361 */ then /* 2362 */ error("Assertion failed: " /* 2363 */ ++ /* 2364 */ $^{["Str", /* 2365 */ actualSrc, /* 2366 */ 0]} /* 2367 */ ++ /* 2368 */ " — expected " /* 2369 */ ++ /* 2370 */ str(e) /* 2371 */ ++ /* 2372 */ ", got " /* 2373 */ ++ /* 2374 */ str(a)) /* 2375 */ else /* 2376 */ true /* 2377 */ end /* 2378 */ end /* 2379 */ end;
/* 2380 */
end;
/* 2381 */
print("── assert / assertEq ──");
/* 2382 */
assert(10 /* 2383 */ > /* 2384 */ 5);
/* 2385 */
assert(isEven(42));
/* 2386 */
assertEq(2 /* 2387 */ + /* 2388 */ 2, /* 2389 */ 4);
/* 2390 */
assertEq("hello" /* 2391 */ ++ /* 2392 */ " world", /* 2393 */ "hello world");
/* 2394 */
assertEq(map([1, /* 2395 */ 2, /* 2396 */ 3], /* 2397 */ -> /* 2398 */ $ /* 2399 */ * /* 2400 */ 10), /* 2401 */ [10, /* 2402 */ 20, /* 2403 */ 30]);
/* 2404 */
print("all assertions passed!");
/* 2405 */
// ─── 4. thread — pipe a value through functions ─────────────
/* 2406 */
// thread(value, f1, f2, f3) becomes f3(f2(f1(value)))
/* 2407 */
// Builds the nested call AST at compile time by folding over
/* 2408 */
// the function arguments. A classic Lisp/Clojure threading macro.
/* 2409 */
let /* 2410 */ thread /* 2411 */ =
/* 2412 */
macro(val, /* 2413 */ ... /* 2414 */ fns) /* 2415 */ -> /* 2416 */ do /* 2417 */ reduce(fns, /* 2418 */ (acc, /* 2419 */ f) /* 2420 */ -> /* 2421 */ call(f, /* 2422 */ [acc]), /* 2423 */ val) /* 2424 */ end;
/* 2425 */
print("── thread ──");
/* 2426 */
// thread(-42, abs, str, count) → count(str(abs(-42))) → 2
/* 2427 */
print(thread(-42, /* 2428 */ abs, /* 2429 */ str, /* 2430 */ count));
/* 2431 */
// thread with collection pipeline
/* 2432 */
print(thread([3, /* 2433 */ 1, /* 2434 */ 4, /* 2435 */ 1, /* 2436 */ 5, /* 2437 */ 9], /* 2438 */ sort, /* 2439 */ reverse, /* 2440 */ count));
/* 2441 */
// ─── 5. tryOr — error recovery macro ────────────────────────
/* 2442 */
// Wraps an expression with a handler that catches errors
/* 2443 */
// and returns a fallback value. Uses fallback(v)(-> body).
/* 2444 */
let /* 2445 */ tryOr /* 2446 */ =
/* 2447 */
macro(expr, /* 2448 */ defaultVal) /* 2449 */ -> /* 2450 */ quote /* 2451 */ fallback($^{defaultVal})(-> /* 2452 */ $^{expr}) /* 2453 */ end;
/* 2454 */
print("── tryOr ──");
/* 2455 */
print(tryOr(10 /* 2456 */ / /* 2457 */ 2, /* 2458 */ -1));
/* 2459 */
print(tryOr(0 /* 2460 */ / /* 2461 */ 0, /* 2462 */ -1));
/* 2463 */
print(tryOr(error("boom"), /* 2464 */ "recovered"));
/* 2465 */
// ─── 6. macroexpand — inspecting generated code ─────────────
/* 2466 */
// macroexpand calls a macro's body and returns the expanded AST
/* 2467 */
// without evaluating it. Combined with prettyPrint from the ast
/* 2468 */
// module, this lets you see exactly what code a macro generates.
/* 2469 */
print("── macroexpand ──");
/* 2470 */
print("unless(x > 0, 42) expands to:");
/* 2471 */
print(
/* 2472 */
"  " /* 2473 */ ++ /* 2474 */ (macroexpand(unless, /* 2475 */ quote /* 2476 */ x /* 2477 */ > /* 2478 */ 0 /* 2479 */ end, /* 2480 */ quote /* 2481 */ 42 /* 2482 */ end) /* 2483 */ |> /* 2484 */ prettyPrint)
/* 2485 */
);
/* 2486 */
print("dbg(x + 1) expands to:");
/* 2487 */
print("  " /* 2488 */ ++ /* 2489 */ (macroexpand(dbg, /* 2490 */ quote /* 2491 */ x /* 2492 */ + /* 2493 */ 1 /* 2494 */ end) /* 2495 */ |> /* 2496 */ prettyPrint));
/* 2497 */
print("thread(v, f, g) expands to:");
/* 2498 */
print(
/* 2499 */
"  " /* 2500 */ ++
/* 2501 */
(macroexpand(thread, /* 2502 */ quote /* 2503 */ v /* 2504 */ end, /* 2505 */ quote /* 2506 */ f /* 2507 */ end, /* 2508 */ quote /* 2509 */ g /* 2510 */ end) /* 2511 */ |> /* 2512 */ prettyPrint)
/* 2513 */
);
/* 2514 */
// ─── 7. Putting it all together ─────────────────────────────
/* 2515 */
// Use the toolkit to build and verify a small utility with confidence.
/* 2516 */
print("── integration demo ──");
/* 2517 */
// A function that computes a letter grade from a percentage score
/* 2518 */
let /* 2519 */ letterGrade /* 2520 */ = /* 2521 */ (pct) /* 2522 */ -> /* 2523 */ if /* 2524 */ pct /* 2525 */ >= /* 2526 */ 90 /* 2527 */ then
/* 2528 */
"A"
/* 2529 */
else /* 2530 */ if /* 2531 */ pct /* 2532 */ >= /* 2533 */ 80 /* 2534 */ then
/* 2535 */
"B"
/* 2536 */
else /* 2537 */ if /* 2538 */ pct /* 2539 */ >= /* 2540 */ 70 /* 2541 */ then
/* 2542 */
"C"
/* 2543 */
else /* 2544 */ if /* 2545 */ pct /* 2546 */ >= /* 2547 */ 60 /* 2548 */ then
/* 2549 */
"D"
/* 2550 */
else
/* 2551 */
"F"
/* 2552 */
end;
/* 2553 */
// Verify with assertEq — if any fail, we get a clear error message
/* 2554 */
assertEq(letterGrade(95), /* 2555 */ "A");
/* 2556 */
assertEq(letterGrade(85), /* 2557 */ "B");
/* 2558 */
assertEq(letterGrade(75), /* 2559 */ "C");
/* 2560 */
assertEq(letterGrade(65), /* 2561 */ "D");
/* 2562 */
assertEq(letterGrade(42), /* 2563 */ "F");
/* 2564 */
print("letterGrade: all 5 tests passed!");
/* 2565 */
// Use thread and dbg to process a list of scores
/* 2566 */
let /* 2567 */ scores /* 2568 */ = /* 2569 */ [88, /* 2570 */ 92, /* 2571 */ 76, /* 2572 */ 95, /* 2573 */ 61];
/* 2574 */
let /* 2575 */ total /* 2576 */ = /* 2577 */ dbg(reduce(scores, /* 2578 */ +, /* 2579 */ 0));
/* 2580 */
let /* 2581 */ avg /* 2582 */ = /* 2583 */ dbg(total /* 2584 */ / /* 2585 */ count(scores));
/* 2586 */
let /* 2587 */ grade /* 2588 */ = /* 2589 */ dbg(letterGrade(avg));
/* 2590 */
// Defensive check with tryOr
/* 2591 */
let /* 2592 */ safeAvg /* 2593 */ = /* 2594 */ tryOr(reduce([], /* 2595 */ +, /* 2596 */ 0) /* 2597 */ / /* 2598 */ 0, /* 2599 */ 0);
/* 2600 */
assertEq(safeAvg, /* 2601 */ 0);
/* 2602 */
print("safe division by zero handled!");
/* 2603 */
// Final assertion
/* 2604 */
assert(grade /* 2605 */ == /* 2606 */ "B" /* 2607 */ || /* 2608 */ grade /* 2609 */ == /* 2610 */ "C");
/* 2611 */
unless(grade /* 2612 */ == /* 2613 */ "F", /* 2614 */ print("The class is doing fine!"));
/* 2615 */
print("── done ──"); end;
