let /* 2091 */ handled /* 2092 */ = /* 2093 */ do
/* 2094 */
with /* 2095 */ fallback("Green");
/* 2096 */
let /* 2097 */ color /* 2098 */ = /* 2099 */ perform(@dvala.io.pick, /* 2100 */ ["Red", /* 2101 */ "Green", /* 2102 */ "Blue"]);
/* 2103 */
color /* 2104 */ ++ /* 2105 */ " was chosen";
/* 2106 */
end;
/* 2107 */
// --- Handler as function ---
/* 2108 */
let /* 2109 */ piped2 /* 2110 */ = /* 2111 */ fallback(1)(-> /* 2112 */ perform(@dvala.io.pick, /* 2113 */ [1, /* 2114 */ 2, /* 2115 */ 3]));
