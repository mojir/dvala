/* 91 */
// Fetch their posts
/* 92 */
let /* 93 */ posts /* 94 */ = /* 95 */ perform(@host.fetchPosts, /* 96 */ 1);
/* 97 */
perform(
/* 98 */
@dvala.io.print,
/* 99 */
"\nFirst " /* 100 */ ++ /* 101 */ str(count(posts)) /* 102 */ ++ /* 103 */ " posts by " /* 104 */ ++ /* 105 */ user.name /* 106 */ ++ /* 107 */ ":"
/* 108 */
);
/* 109 */
for(post /* 110 */ in /* 111 */ posts) /* 112 */ -> /* 113 */ perform(@dvala.io.print, /* 114 */ "- " /* 115 */ ++ /* 116 */ post.title); end;

// --- Interactive async ---
do // Interactive async example
/* 117 */
// Uses dvala.io.read for user input and host.fetch-* for API calls
/* 118 */
let /* 119 */ lookupUser /* 120 */ = /* 121 */ (idStr) /* 122 */ -> /* 123 */ do
/* 124 */
let /* 125 */ id /* 126 */ = /* 127 */ number(idStr);
/* 128 */
if /* 129 */ !(isNumber(id)) /* 130 */ || /* 131 */ id /* 132 */ < /* 133 */ 1 /* 134 */ || /* 135 */ id /* 136 */ > /* 137 */ 10 /* 138 */ then
/* 139 */
perform(
/* 140 */
@dvala.io.print,
/* 141 */
"Invalid user ID: " /* 142 */ ++ /* 143 */ idStr /* 144 */ ++ /* 145 */ ". Please enter 1-10."
/* 146 */
)
/* 147 */
else
/* 148 */
perform(@dvala.io.print, /* 149 */ "Fetching user " /* 150 */ ++ /* 151 */ str(id) /* 152 */ ++ /* 153 */ "...");
/* 154 */
let /* 155 */ user /* 156 */ = /* 157 */ perform(@host.fetchUser, /* 158 */ id);
/* 159 */
if /* 160 */ isNull(user) /* 161 */ then
/* 162 */
perform(@dvala.io.print, /* 163 */ "User not found.")
/* 164 */
else
/* 165 */
perform(@dvala.io.print, /* 166 */ "Name:    " /* 167 */ ++ /* 168 */ user.name);
/* 169 */
perform(@dvala.io.print, /* 170 */ "Email:   " /* 171 */ ++ /* 172 */ user.email);
/* 173 */
perform(@dvala.io.print, /* 174 */ "City:    " /* 175 */ ++ /* 176 */ user.city);
/* 177 */
perform(@dvala.io.print, /* 178 */ "Company: " /* 179 */ ++ /* 180 */ user.company);
/* 181 */
user
/* 182 */
end
/* 183 */
end;
/* 184 */
end;
/* 185 */
let /* 186 */ showTodos /* 187 */ = /* 188 */ (user) /* 189 */ -> /* 190 */ do
/* 191 */
perform(@dvala.io.print, /* 192 */ "\nFetching todos for " /* 193 */ ++ /* 194 */ user.name /* 195 */ ++ /* 196 */ "...");
/* 197 */
let /* 198 */ todos /* 199 */ = /* 200 */ perform(@host.fetchTodos, /* 201 */ user.id);
/* 202 */
let /* 203 */ done /* 204 */ = /* 205 */ filter(todos, /* 206 */ -> /* 207 */ $.completed);
/* 208 */
let /* 209 */ pending /* 210 */ = /* 211 */ filter(todos, /* 212 */ -> /* 213 */ !($.completed));
/* 214 */
perform(
/* 215 */
@dvala.io.print,
/* 216 */
"\nCompleted (" /* 217 */ ++ /* 218 */ str(count(done)) /* 219 */ ++ /* 220 */ "/" /* 221 */ ++ /* 222 */ str(count(todos)) /* 223 */ ++ /* 224 */ "):"
/* 225 */
);
/* 226 */
for(t /* 227 */ in /* 228 */ done /* 229 */ take /* 230 */ 5) /* 231 */ -> /* 232 */ perform(@dvala.io.print, /* 233 */ "  ✓ " /* 234 */ ++ /* 235 */ t.title);
/* 236 */
if /* 237 */ count(done) /* 238 */ > /* 239 */ 5 /* 240 */ then
/* 241 */
perform(@dvala.io.print, /* 242 */ "  ... and " /* 243 */ ++ /* 244 */ str(count(done) /* 245 */ - /* 246 */ 5) /* 247 */ ++ /* 248 */ " more")
/* 249 */
end;
/* 250 */
perform(@dvala.io.print, /* 251 */ "\nPending (" /* 252 */ ++ /* 253 */ str(count(pending)) /* 254 */ ++ /* 255 */ "):");
/* 256 */
for(t /* 257 */ in /* 258 */ pending /* 259 */ take /* 260 */ 5) /* 261 */ -> /* 262 */ perform(@dvala.io.print, /* 263 */ "  ○ " /* 264 */ ++ /* 265 */ t.title);
/* 266 */
if /* 267 */ count(pending) /* 268 */ > /* 269 */ 5 /* 270 */ then
/* 271 */
perform(@dvala.io.print, /* 272 */ "  ... and " /* 273 */ ++ /* 274 */ str(count(pending) /* 275 */ - /* 276 */ 5) /* 277 */ ++ /* 278 */ " more")
/* 279 */
end;
/* 280 */
end;
/* 281 */
// Main interaction loop
/* 282 */
let /* 283 */ main /* 284 */ = /* 285 */ () /* 286 */ -> /* 287 */ do
/* 288 */
perform(@dvala.io.print, /* 289 */ "=== User Lookup Tool ===\n");
/* 290 */
loop(cont /* 291 */ = /* 292 */ true) /* 293 */ -> /* 294 */ if /* 295 */ cont /* 296 */ then
/* 297 */
let /* 298 */ input /* 299 */ =
/* 300 */
perform(@dvala.io.read, /* 301 */ "Enter a user ID (1-10), or cancel to quit:");
/* 302 */
if /* 303 */ isNull(input) /* 304 */ || /* 305 */ input /* 306 */ == /* 307 */ "" /* 308 */ then
/* 309 */
perform(@dvala.io.print, /* 310 */ "Goodbye!")
/* 311 */
else
/* 312 */
let /* 313 */ user /* 314 */ = /* 315 */ lookupUser(input);
/* 316 */
if /* 317 */ user /* 318 */ then
/* 319 */
let /* 320 */ show /* 321 */ =
/* 322 */
perform(
/* 323 */
@dvala.io.read,
/* 324 */
"Show todos for " /* 325 */ ++ /* 326 */ user.name /* 327 */ ++ /* 328 */ "? (yes/no)"
/* 329 */
);
/* 330 */
if /* 331 */ show /* 332 */ == /* 333 */ "yes" /* 334 */ then /* 335 */ showTodos(user) /* 336 */ else /* 337a */ null /* 337b */ end
/* 337 */
end;
/* 338 */
perform(@dvala.io.print, /* 339 */ "");
/* 340 */
recur(true)
/* 341 */
end
/* 342 */
else
/* 343 */
null
/* 344 */
end;
/* 345 */
end;
/* 346 */
main(); end;

