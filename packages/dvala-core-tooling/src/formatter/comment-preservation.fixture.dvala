/* 49 */
// Any expression works inside ${...}
/* 50 */
let /* 51 */ items /* 52 */ = /* 53 */ ["apple", /* 54 */ "banana", /* 55 */ "cherry"];
/* 56 */
for(i /* 57 */ in /* 58 */ range(count(items))) /* 59 */ -> /* 60 */ perform(
/* 61 */
@dvala.io.print,
/* 62 */
`${i + 1}. ${items[i]}`
/* 63 */
); end;

// --- Using context ---
do perform(@host.plus, /* 64 */ [x, /* 65 */ y]); end;

// --- Async host effects ---
do // Call async host effects with perform(effect, args...)
/* 66 */
// Simulate a delay
/* 67 */
perform(@dvala.io.print, /* 68 */ "Waiting 500ms...");
/* 69 */
perform(@host.delay, /* 70 */ 500);
/* 71 */
perform(@dvala.io.print, /* 72 */ "Done waiting!");
/* 73 */
// Fetch a user from a REST API
/* 74 */
let /* 75 */ user /* 76 */ = /* 77 */ perform(@host.fetchUser, /* 78 */ 1);
/* 79 */
