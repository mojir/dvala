{
  "compilerOptions": {
    "noErrorTruncation": true,
    "target": "es2023",
    "lib": [
      "ESNext",
      "DOM"
    ] /* Specify ECMAScript target version: 'ES3' (default), 'ES5', 'ES2015', 'ES2016', 'ES2017', 'ES2018', 'ES2019', 'ES2020', or 'ESNEXT'. */,
    "module": "es2020" /* Include 'undefined' in index signature results */,
    "moduleResolution": "bundler" /* Bundler-style resolution; matches rolldown/vitest/esbuild. */,
    "paths": {
      "@mojir/dvala-runtime": ["./packages/dvala-runtime/src/index.ts"],
      "@mojir/dvala-types": ["./packages/dvala-types/src/index.ts"],
      "@mojir/dvala-engine": ["./packages/dvala-engine/src/index.ts"],
      "@mojir/dvala-core-tooling": ["./packages/dvala-core-tooling/src/index.ts"],
      "@mojir/dvala-test-framework": ["./packages/dvala-test-framework/src/index.ts"],
      "@mojir/dvala-workspace-backend": ["./packages/dvala-workspace-backend/src/index.ts"],
      "@mojir/dvala-workspace-backend/runtime": ["./packages/dvala-workspace-backend/src/runtime/index.ts"],
      "@mojir/dvala-workspace-backend/adapters/playground-worker-protocol": [
        "./packages/dvala-workspace-backend/src/adapters/playgroundWorkerProtocol.ts"
      ]
    },
    "resolveJsonModule": true /* Specify module code generation: 'none', 'commonjs', 'amd', 'system', 'umd', 'es2015', 'es2020', or 'ESNext'. */,
    "typeRoots": ["./node_modules/@types", "./types"] /* List of library files to be included in the compilation. */,
    "types": ["node"],
    "strict": true /* Enable strict checking of function types. */,
    "strictBindCallApply": true /* Enable strict null checks. */,
    "strictFunctionTypes": true /* Raise error on expressions and declarations with an implied 'any' type. */,
    "strictNullChecks": true /* Enable strict 'bind', 'call', and 'apply' methods on functions. */,
    "strictPropertyInitialization": true /* Raise error on 'this' expressions with an implied 'any' type. */,
    "alwaysStrict": true /* Report error when not all code paths in function return a value. */,
    "noFallthroughCasesInSwitch": true /* Enable all strict type-checking options. */,
    "noImplicitAny": true /* Report errors on unused parameters. */,
    "noImplicitReturns": true /* Enable strict checking of property initialization in classes. */,
    "noImplicitThis": true /* Report errors for fallthrough cases in switch statement. */,
    "noUncheckedIndexedAccess": true /* Parse in strict mode and emit "use strict" for each source file. */,
    "noUnusedLocals": true /* Report errors on unused locals. */,
    "noUnusedParameters": true /* Allow javascript files to be compiled. */,
    "declaration": true,
    "outDir": "./dist",
    "declarationDir": "./dist" /* Generates corresponding '.d.ts' file. */,
    "esModuleInterop": true /* Skip type checking of declaration files. */,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true /* Enables emit interoperability between CommonJS and ES Modules via creation of module objects for all imports. Implies 'allowSyntheticDefaultImports'. */,
    "skipLibCheck": true
  },
  "include": ["types/**/*", "cli/**/*", "common/clojureDocs.ts"],
  "exclude": ["**/*.test.ts", "__tests__"]
}
