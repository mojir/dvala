// A logging effect that accumulates messages internally.
// The handler captures all log entries — nothing leaks to the host.
let withLogging = (thunk) -> do
  let h =
    handler
      @project.log(msg) -> do
        let resumed = resume(null);
        { result: resumed.result, logs: [msg] ++ resumed.logs };
      end
      transform result ->  { result, logs: [] }
    end;
  h(thunk);
end;

{ withLogging };
