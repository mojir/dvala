let { test, describe } = import("test");
let { assertTrue } = import("assertion");
let constants = import("../lib/constants");

describe("constants", -> do
  test("pi is approximately 3.14", -> do
    assertTrue(constants.pi > 3.14);
    assertTrue(constants.pi < 3.15);
  end);
  test("e is approximately 2.718", -> do
    assertTrue(constants.e > 2.718);
    assertTrue(constants.e < 2.719);
  end);
  test("phi is approximately 1.618", -> do
    assertTrue(constants.phi > 1.618);
    assertTrue(constants.phi < 1.619);
  end);
end);
