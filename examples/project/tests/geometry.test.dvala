let { test, describe } = import("test");
let { assertEqual, assertTrue } = import("assertion");
let { pi, distance, midpoint, circleArea, scale } = import("../lib/geometry.dvala");

describe("distance", -> do
  test("horizontal", -> assertEqual(distance(0, 0, 3, 0), 3));
  test("vertical", -> assertEqual(distance(0, 0, 0, 4), 4));
  test("diagonal 3-4-5", -> assertEqual(distance(0, 0, 3, 4), 5));
end);

describe("midpoint", -> do
  test("origin to (4, 6)", -> do
    let m = midpoint(0, 0, 4, 6);
    assertEqual(m.x, 2);
    assertEqual(m.y, 3);
  end);
end);

describe("circleArea", -> do
  test("unit circle", -> do
    let a = circleArea(1);
    assertTrue(a > 3.14);
    assertTrue(a < 3.15);
  end);
end);

describe("scale", -> do
  test("double a point", -> do
    let p = scale({ x: 3, y: 4 }, 2);
    assertEqual(p.x, 6);
    assertEqual(p.y, 8);
  end);
end);
