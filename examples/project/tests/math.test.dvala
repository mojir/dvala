let { test, describe } = import("test");
let { assertEqual, assertTrue, assertFalse } = import("assertion");
let { clamp, lerp, inRange } = import("../lib/math");

describe("clamp", -> do
  test("within range", -> assertEqual(clamp(5, 0, 10), 5));
  test("below min", -> assertEqual(clamp(-5, 0, 10), 0));
  test("above max", -> assertEqual(clamp(15, 0, 10), 10));
  test("at boundaries", -> do
    assertEqual(clamp(0, 0, 10), 0);
    assertEqual(clamp(10, 0, 10), 10)
  end)
end);

describe("lerp", -> do
  test("start", -> assertEqual(lerp(0, 10, 0), 0));
  test("end", -> assertEqual(lerp(0, 10, 1), 10));
  test("midpoint", -> assertEqual(lerp(0, 10, 0.5), 5));
  test("quarter", -> assertEqual(lerp(0, 100, 0.25), 25))
end);

describe("inRange", -> do
  test("inside", -> assertTrue(inRange(5, 0, 10)));
  test("below", -> assertFalse(inRange(-1, 0, 10)));
  test("above", -> assertFalse(inRange(11, 0, 10)));
  test("at boundaries", -> do
    assertTrue(inRange(0, 0, 10));
    assertTrue(inRange(10, 0, 10))
  end)
end);
