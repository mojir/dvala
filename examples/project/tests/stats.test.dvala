let { test, describe } = import("test");
let { assertEqual } = import("assertion");
let { sum, average, variance } = import("../lib/stats.dvala");

describe("sum", -> do
  test("of list", -> assertEqual(sum([1, 2, 3, 4]), 10));
  test("of empty", -> assertEqual(sum([]), 0));
  test("of single", -> assertEqual(sum([42]), 42));
  test("of negatives", -> assertEqual(sum([-1, -2, -3]), -6));
end);

describe("average", -> do
  test("simple", -> assertEqual(average([2, 4, 6]), 4));
  test("single value", -> assertEqual(average([7]), 7));
  test("with negatives", -> assertEqual(average([-2, 2]), 0));
end);

describe("variance", -> do
  test("uniform values", -> assertEqual(variance([5, 5, 5]), 0));
  test("simple spread", -> assertEqual(variance([1, 3]), 1));
  test("known case", -> do
    // variance of [2, 4, 4, 4, 5, 5, 7, 9] = 4
    assertEqual(variance([2, 4, 4, 4, 5, 5, 7, 9]), 4);
  end);
end);
