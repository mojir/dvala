{
  mapcat: (arr, fn) -> do
    flatten(map(arr, fn), 1)
  end,

  moving-fn: (arr, window-size, fn) -> do
    if window-size > count(arr) then
      perform(effect(dvala.error), "Expected window-size <= array length")
    end;
    for (i in range(count(arr) - window-size + 1)) -> do
      fn(slice(arr, i, i + window-size))
    end
  end,

  running-fn: (arr, fn) -> do
    for (i in range(count(arr))) -> do
      fn(slice(arr, 0, i + 1))
    end
  end
}
