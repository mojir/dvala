  {
    fibonacciTakeWhile: (fn) -> loop(result = [], a = 0, b = 1, i = 0) -> if fn(
      a,
      i
    ) then
      recur(push(result, a), b, a + b, i + 1)
    else
      result
    end,
    tribonacciTakeWhile: (fn) -> loop(result = [], a = 0, b = 1, c = 1, i = 0) -> if fn(
      a,
      i
    ) then
      recur(push(result, a), b, c, a + b + c, i + 1)
    else
      result
    end,
    lucasTakeWhile: (fn) -> loop(result = [], a = 2, b = 1, i = 0) -> if fn(
      a,
      i
    ) then
      recur(push(result, a), b, a + b, i + 1)
    else
      result
    end,
    pellTakeWhile: (fn) -> loop(result = [], a = 1, b = 2, i = 0) -> if fn(a, i) then
      recur(push(result, a), b, 2 * b + a, i + 1)
    else
      result
    end,
    padovanTakeWhile: (fn) -> loop(result = [], a = 1, b = 1, c = 1, i = 0) -> if fn(
      a,
      i
    ) then
      recur(push(result, a), b, c, a + b, i + 1)
    else
      result
    end,
    factorialTakeWhile: (fn) -> loop(result = [], fact = 1, i = 0) -> if fn(
      fact,
      i
    ) then
      recur(push(result, fact), fact * (i + 1), i + 1)
    else
      result
    end,
    primeTakeWhile: (fn) -> loop(result = [], n = 2) -> if isPrime(n) then
      if fn(n, count(result)) then recur(push(result, n), n + 1) else result end
    else
      recur(result, n + 1)
    end,
    compositeTakeWhile: (fn) -> loop(result = [], n = 4) -> if isComposite(n) then
      if fn(n, count(result)) then recur(push(result, n), n + 1) else result end
    else
      recur(result, n + 1)
    end,
    abundantTakeWhile: (fn) -> loop(result = [], n = 12) -> if isAbundant(n) then
      if fn(n, count(result)) then recur(push(result, n), n + 1) else result end
    else
      recur(result, n + 1)
    end,
    deficientTakeWhile: (fn) -> loop(result = [], n = 1) -> if isDeficient(n) then
      if fn(n, count(result)) then recur(push(result, n), n + 1) else result end
    else
      recur(result, n + 1)
    end,
    perfectSquareTakeWhile: (fn) -> loop(result = [], i = 1) -> do
      let val = i * i;
      if fn(val, i - 1) then recur(push(result, val), i + 1) else result end;
    end,
    perfectCubeTakeWhile: (fn) -> loop(result = [], i = 1) -> do
      let val = i * i * i;
      if fn(val, i - 1) then recur(push(result, val), i + 1) else result end;
    end,
    happyTakeWhile: (fn) -> loop(result = [], n = 1) -> if isHappy(n) then
      if fn(n, count(result)) then recur(push(result, n), n + 1) else result end
    else
      recur(result, n + 1)
    end,
    arithmeticTakeWhile: (start, step, fn) -> loop(result = [], i = 0) -> do
      let val = start + i * step;
      if fn(val, i) then recur(push(result, val), i + 1) else result end;
    end,
    geometricTakeWhile: (start, ratio, fn) -> loop(result = [], i = 0) -> do
      let val = start * ratio ^ i;
      if fn(val, i) then recur(push(result, val), i + 1) else result end;
    end,
    polygonalTakeWhile: (sides, fn) -> loop(result = [], n = 1) -> do
      let val = (sides - 2) * n * (n - 1) / 2 + n;
      if fn(val, n - 1) then recur(push(result, val), n + 1) else result end;
    end,
    lookAndSayTakeWhile: (fn) -> do
      let nextTerm = (s) -> loop(result = "", i = 0) -> if i >= count(s) then
        result
      else
        do
          let ch = nth(s, i);
          let cnt =
            loop(c = 1, j = i + 1) -> if j < count(s) && nth(s, j) == ch then
              recur(c + 1, j + 1)
            else
              c
            end;
          recur(++(result, str(cnt), ch), i + cnt);
        end
      end;
      loop(result = [], term = "1", idx = 0) -> if fn(term, idx) then
        recur(push(result, term), nextTerm(term), idx + 1)
      else
        result
      end;
    end,
    bellTakeWhile: (fn) -> loop(result = [], i = 0) -> if i >=
      count(bellNumbers) then
      result
    else if fn(nth(bellNumbers, i), i) then
      recur(push(result, nth(bellNumbers, i)), i + 1)
    else
      result
    end,
    catalanTakeWhile: (fn) -> loop(result = [], i = 0) -> if i >=
      count(catalanNumbers) then
      result
    else if fn(nth(catalanNumbers, i), i) then
      recur(push(result, nth(catalanNumbers, i)), i + 1)
    else
      result
    end,
    mersenneTakeWhile: (fn) -> loop(result = [], i = 0) -> if i >=
      count(mersenneNumbers) then
      result
    else if fn(nth(mersenneNumbers, i), i) then
      recur(push(result, nth(mersenneNumbers, i)), i + 1)
    else
      result
    end,
    partitionTakeWhile: (fn) -> loop(result = [], i = 0) -> if i >=
      count(partitionNumbers) then
      result
    else if fn(nth(partitionNumbers, i), i) then
      recur(push(result, nth(partitionNumbers, i)), i + 1)
    else
      result
    end,
    perfectTakeWhile: (fn) -> loop(result = [], i = 0) -> if i >=
      count(perfectNumbers) then
      result
    else if fn(nth(perfectNumbers, i), i) then
      recur(push(result, nth(perfectNumbers, i)), i + 1)
    else
      result
    end,
    sylvesterTakeWhile: (fn) -> loop(result = [], i = 0) -> if i >=
      count(sylvesterNumbers) then
      result
    else if fn(nth(sylvesterNumbers, i), i) then
      recur(push(result, nth(sylvesterNumbers, i)), i + 1)
    else
      result
    end,
    bernoulliTakeWhile: (fn) -> loop(bArr = [1], n = 1) -> do
      let bn =
        if n > 1 && n % 2 == 1 then
          0
        else
          do
            let s =
              loop(k = 0, acc = 0) -> if k >= n then
                acc
              else
                recur(k + 1, acc + binom(n + 1, k) * nth(bArr, k))
              end;
            (-s) / (n + 1);
          end
        end;
      if fn(bn, n) then recur(push(bArr, bn), n + 1) else bArr end;
    end,
    golombTakeWhile: (fn) -> if not(fn(1, 0)) then
      []
    else
      do
        loop(gArr = [1], n = 2) -> do
          let gn1 = nth(gArr, n - 2);
          let ggn1 = nth(gArr, gn1 - 1);
          let gval = 1 + nth(gArr, n - 1 - ggn1);
          if fn(gval, n - 1) then recur(push(gArr, gval), n + 1) else gArr end;
        end;
      end
    end,
    luckyTakeWhile: (fn) -> loop(result = [], i = 0) -> if i >=
      count(luckyNumbers) then
      result
    else if fn(nth(luckyNumbers, i), i) then
      recur(push(result, nth(luckyNumbers, i)), i + 1)
    else
      result
    end,
    perfectPowerTakeWhile: (fn) -> loop(result = [], n = 1) -> if isPerfectPower(
      n
    ) then
      if fn(n, count(result)) then recur(push(result, n), n + 1) else result end
    else
      recur(result, n + 1)
    end,
    recamanTakeWhile: (fn) -> do
      let inArr = (arr, val) -> loop(i = 0) -> if i >= count(arr) then
        false
      else if nth(arr, i) == val then
        true
      else
        recur(i + 1)
      end;
      if not(fn(0, 0)) then
        []
      else
        do
          loop(result = [0], n = 1) -> do
            let prev = nth(result, n - 1);
            let backward = prev - n;
            let nxt =
              if backward > 0 && not(inArr(result, backward)) then
                backward
              else
                prev + n
              end;
            if fn(nxt, n) then recur(push(result, nxt), n + 1) else result end;
          end;
        end
      end;
    end,
    thueMorseTakeWhile: (fn) -> loop(result = [], i = 0) -> do
      let val = countBits(i) % 2;
      if fn(val, i) then recur(push(result, val), i + 1) else result end;
    end,
  };
end;
// Helper predicates
// =========================================================================
// FINITE SEQUENCES — generate inline
// =========================================================================
// =========================================================================
// PREDICATE SEQUENCES — use inline predicates
// =========================================================================
// =========================================================================
// PARAMETERIZED SEQUENCES
// =========================================================================
// =========================================================================
// FINITE SEQUENCES — iterate precomputed arrays
// =========================================================================
// =========================================================================
// DYNAMIC SEQUENCES — generate on-the-fly
// =========================================================================
// bArr accumulates all Bernoulli numbers computed so far; B(0)=1 is always included
// gArr is 0-indexed: gArr[i] = g(i+1). g(1)=1, g(n)=1+g(n-g(g(n-1)))
