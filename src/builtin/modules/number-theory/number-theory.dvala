do
  let isPrime = (n) -> if n < 2 then
    false
  else if n == 2 then
    true
  else if n % 2 == 0 then
    false
  else
    loop(i = 3) -> if i * i > n then
      true
    else if n % i == 0 then
      false
    else
      recur(i + 2)
    end
  end;

  let isPerfectSquare = (n) -> if n < 0 then
    false
  else
    do
      let s = floor(sqrt(n));
      s * s == n;
    end
  end;
  let isPerfectCube = (n) -> do
    let c = round(sign(n) * abs(n) ^ (1 / 3));
    c * c * c == n;
  end;
  let sumProperDivisors = (n) -> if n <= 1 then
    0
  else
    loop(i = 2, acc = 1) -> if i * i > n then
      acc
    else if n % i == 0 then
      if i * i == n then
        recur(i + 1, acc + i)
      else
        recur(i + 1, acc + i + n / i)
      end
    else
      recur(i + 1, acc)
    end
  end;
  let isAbundant = (n) -> n > 0 && sumProperDivisors(n) > n;
  let isDeficient = (n) -> n > 0 && sumProperDivisors(n) < n;
  let isComposite = (n) -> n > 1 && not(isPrime(n));
  let isHappy = (n) -> do
    let sumOfSquaredDigits = (x) -> loop(num = x, acc = 0) -> if num == 0 then
      acc
    else
      do
        let d = num % 10;
        recur(floor(num / 10), acc + d * d);
      end
    end;
    loop(slow = n, fast = sumOfSquaredDigits(n)) -> if fast == 1 then
      true
    else if slow == fast then
      false
    else
      recur(
        sumOfSquaredDigits(slow),
        sumOfSquaredDigits(sumOfSquaredDigits(fast))
      )
    end;
  end;
  let countBits = (n) -> loop(x = n, acc = 0) -> if x == 0 then
    acc
  else
    recur(floor(x / 2), acc + x % 2)
  end;
  let isPerfectPower = (n) -> if n == 1 then
    true
  else if n < 2 then
    false
  else
    loop(k = 2) -> if 2 ^ k > n then
      false
    else
      do
        let b = round(n ^ (1 / k));
        if b ^ k == n then true else recur(k + 1) end;
      end
    end
  end;
  let binom = (n, k) -> if k == 0 || k == n then
    1
  else
    loop(i = 0, k2 = min(k, n - k), acc = 1) -> if i >= k2 then
      acc
    else
      recur(i + 1, k2, acc * (n - i) / (i + 1))
    end
  end;
