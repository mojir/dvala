{
  fallback: (value) -> handler @dvala.error(msg) -> value end,

  retry: (n, bodyFn) ->
    loop (remaining = n) ->
      do
        with (handler @dvala.error(msg) ->
          if remaining > 0 then recur(remaining - 1)
          else perform(@dvala.error, msg)
          end
        end);
        bodyFn()
      end
}
