{
  retry: (n) -> (arg, eff, nxt) ->
    if eff == @dvala.error then nxt(eff, arg)
    else
      loop (remaining = n) ->
        handle nxt(eff, arg)
        with @dvala.error(msg) ->
          if remaining > 0 then recur(remaining - 1)
          else nxt(@dvala.error, msg)
          end
        end
    end,

  fallback: (value) -> @dvala.error(msg) -> value
}
