// Human-in-the-loop Email Workflow
//
// Flow (repeats until approved):
//   1. Author writes / revises draft        → dvala.io.read  (suspend + share)
//   2. LLM polishes the draft               → llm.ask
//   3. Approver reviews the polished text   → human.approve       (suspend + share)
//   4a. Approved  → done
//   4b. Rejected  → loop back to step 1 with LLM text + feedback

let editDraft = (previous, feedback, attempt) -> do
  perform(
    @dvala.io.print,
    "✏️  STEP 1 — WRITE YOUR DRAFT (attempt " ++ str(attempt) ++ ")"
  );

  if feedback != "" then
    perform(@dvala.io.print, "Approver feedback: \"" ++ feedback ++ "\"");
    perform(@dvala.io.print, "Previous version:\n" ++ previous ++ "\n")
  end;

  perform(@dvala.io.read, "Your draft:\n");
end;

let polish = (draft) -> do
  perform(@dvala.io.print, "\n🤖 STEP 2 — LLM POLISH");
  perform(@dvala.io.print, "Improving your draft...\n");

  let polished =
    perform(
      @llm.ask,
      "Improve this email for a professional audience. " ++
        "Keep it concise and engaging. " ++
        "Reply with only the improved email text, no commentary.\n\n" ++
        draft
    );

  perform(@dvala.io.print, polished);
  polished;
end;

let requestApproval = (text, attempt) -> do
  perform(@dvala.io.print, "\n👤 STEP 3 — APPROVAL REQUEST");
  perform(@dvala.io.print, "Waiting for approver...\n");

  perform(@human.approve, { text: text, attempt: attempt });
end;

let run = (previous, feedback, attempt) -> do
  let draft = editDraft(previous, feedback, attempt);
  let polished = polish(draft);
  let decision = requestApproval(polished, attempt);

  if decision.approved then
    perform(@dvala.io.print, "\n✅ APPROVED — sending email to all subscribers.");
    perform(@dvala.io.print, "\nFinal email:\n" ++ polished);
    { sent: true, text: polished, attempts: attempt }
  else
    perform(@dvala.io.print, "\n↩️  REJECTED — looping back to author.\n");
    run(polished, decision.comment, attempt + 1)
  end;
end;

perform(@dvala.io.print, "📧 EMAIL CAMPAIGN EDITOR");
perform(
  @dvala.io.print,
  "Write a draft, let the LLM polish it, get it approved.\n"
);

run("", "", 1);
