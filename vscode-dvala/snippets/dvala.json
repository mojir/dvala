{
  "Lambda": {
    "prefix": "fn",
    "body": ["($1) -> $2"],
    "description": "Lambda function"
  },
  "Let binding": {
    "prefix": "let",
    "body": ["let $1 = $2;"],
    "description": "Let binding"
  },
  "If-then-else": {
    "prefix": "if",
    "body": [
      "if $1 then",
      "\t$2",
      "else",
      "\t$3",
      "end"
    ],
    "description": "If-then-else expression"
  },
  "If-then": {
    "prefix": "ift",
    "body": [
      "if $1 then",
      "\t$2",
      "end"
    ],
    "description": "If-then expression (no else)"
  },
  "For loop": {
    "prefix": "for",
    "body": ["for ($1 in $2) -> $3"],
    "description": "For loop"
  },
  "For loop (multiline)": {
    "prefix": "form",
    "body": [
      "for ($1 in $2) -> do",
      "\t$3",
      "end"
    ],
    "description": "For loop with do block body"
  },
  "Match": {
    "prefix": "match",
    "body": [
      "match $1",
      "\tcase $2 then $3",
      "\tcase _ then $4",
      "end"
    ],
    "description": "Pattern match expression"
  },
  "Loop": {
    "prefix": "loop",
    "body": [
      "loop ($1 = $2) -> do",
      "\tif $3 then",
      "\t\t$4",
      "\telse",
      "\t\trecur($5)",
      "\tend",
      "end"
    ],
    "description": "Loop with recur"
  },
  "Do block": {
    "prefix": "do",
    "body": [
      "do",
      "\t$1",
      "end"
    ],
    "description": "Do block"
  },
  "Handle-with": {
    "prefix": "handle",
    "body": [
      "handle",
      "\t$1",
      "with $2",
      "end"
    ],
    "description": "Handle-with effect handler"
  },
  "Effect pipe": {
    "prefix": "||>",
    "body": ["||> $1"],
    "description": "Effect pipe operator"
  },
  "Handler shorthand": {
    "prefix": "@",
    "body": ["@$1($2) -> $3"],
    "description": "Handler shorthand: @effect(param) -> body"
  },
  "Perform": {
    "prefix": "perf",
    "body": ["perform(@$1, $2)"],
    "description": "Perform an effect"
  }
}
