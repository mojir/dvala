{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Dvala",
  "scopeName": "source.dvala",
  "patterns": [
    { "include": "#comments" },
    { "include": "#docstrings" },
    { "include": "#template-strings" },
    { "include": "#strings" },
    { "include": "#regexp-shorthand" },
    { "include": "#effect-names" },
    { "include": "#numeric-constants" },
    { "include": "#numbers" },
    { "include": "#reserved-symbols" },
    { "include": "#special-expressions" },
    { "include": "#builtin-functions" },
    { "include": "#operators" },
    { "include": "#brackets" },
    { "include": "#symbols" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.dvala",
          "match": "//.*$"
        },
        {
          "name": "comment.line.shebang.dvala",
          "match": "^#!.*$"
        },
        {
          "name": "comment.block.dvala",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.begin.dvala" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.end.dvala" }
          }
        }
      ]
    },
    "docstrings": {
      "patterns": [
        {
          "name": "string.quoted.triple.dvala",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.dvala" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.dvala" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.dvala",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "template-strings": {
      "patterns": [
        {
          "name": "string.template.dvala",
          "begin": "`",
          "end": "`",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.template.begin.dvala" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.template.end.dvala" }
          },
          "patterns": [
            {
              "name": "meta.template.expression.dvala",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.template-expression.begin.dvala" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.definition.template-expression.end.dvala" }
              },
              "patterns": [
                { "include": "#comments" },
                { "include": "#template-strings" },
                { "include": "#strings" },
                { "include": "#effect-names" },
                { "include": "#numbers" },
                { "include": "#reserved-symbols" },
                { "include": "#special-expressions" },
                { "include": "#builtin-functions" },
                { "include": "#operators" },
                { "include": "#brackets" },
                { "include": "#symbols" }
              ]
            },
            {
              "name": "constant.character.escape.dvala",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.dvala",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.dvala" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.dvala" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.dvala",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "regexp-shorthand": {
      "patterns": [
        {
          "name": "string.regexp.dvala",
          "match": "#\"(?:[^\"\\\\]|\\\\.)*\"[gi]*"
        }
      ]
    },
    "effect-names": {
      "patterns": [
        {
          "comment": "Effect name literal: @name or @dotted.name",
          "match": "(@)([a-zA-Z_$][a-zA-Z0-9_$]*(?:\\.[a-zA-Z_$][a-zA-Z0-9_$]*)*(?:\\.\\*)?)",
          "captures": {
            "1": { "name": "punctuation.definition.effect-name.dvala" },
            "2": { "name": "support.constant.effect-name.dvala" }
          }
        }
      ]
    },
    "numeric-constants": {
      "patterns": [
        {
          "name": "constant.language.dvala",
          "match": "(?<=[\\s(\\[{,;]|^)(-?(?:E|ε|PI|π|PHI|φ|POSITIVE_INFINITY|NEGATIVE_INFINITY|∞|MAX_SAFE_INTEGER|MIN_SAFE_INTEGER|MAX_VALUE|MIN_VALUE|NaN))(?=[\\s)\\]},;]|$)"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.dvala",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.octal.dvala",
          "match": "\\b0[oO][0-7]+\\b"
        },
        {
          "name": "constant.numeric.binary.dvala",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.decimal.dvala",
          "match": "(?<=[\\s(\\[{,;:=]|^)-?\\d[\\d_]*(?:\\.\\d[\\d_]*)?(?:[eE][+-]?\\d+)?(?=[\\s)\\]},;:]|$)"
        }
      ]
    },
    "reserved-symbols": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.dvala",
          "match": "(?<=[\\s(\\[{,;]|^)true(?=[\\s)\\]},;]|$)"
        },
        {
          "name": "constant.language.boolean.false.dvala",
          "match": "(?<=[\\s(\\[{,;]|^)false(?=[\\s)\\]},;]|$)"
        },
        {
          "name": "constant.language.null.dvala",
          "match": "(?<=[\\s(\\[{,;]|^)null(?=[\\s)\\]},;]|$)"
        },
        {
          "comment": "Control-flow reserved words: do, else, case, each, in, when, while, function, as, then, end, with, _",
          "name": "keyword.control.dvala",
          "match": "(?<=[\\s(\\[{,;]|^)(?:do|else|case|each|in|when|while|function|as|then|end|with|_)(?=[\\s)\\]},;]|$)"
        }
      ]
    },
    "special-expressions": {
      "patterns": [
        {
          "comment": "Special expressions: if, let, for, match, loop, block, import, perform, handle, with, parallel, race, recur",
          "name": "keyword.control.dvala",
          "match": "(?<=[\\s(\\[{,;]|^)(?:if|let|for|match|loop|block|import|perform|handle|with|parallel|race|recur)(?=[\\s(\\[{)\\]},;]|$)"
        }
      ]
    },
    "builtin-functions": {
      "patterns": [
        {
          "comment": "Predicates (is-prefix)",
          "name": "entity.name.function.dvala",
          "match": "(?<=[\\s(\\[{,;]|^)(?:assert|isFunction|isString|isNumber|isInteger|isBoolean|isNull|isZero|isPos|isNeg|isEven|isOdd|isArray|isCollection|isSequence|isObject|isRegexp|isEffect|isFinite|isPositiveInfinity|isNegativeInfinity|isTrue|isFalse|isEmpty|isNotEmpty|isVector|isMatrix|isGrid|isBlank)(?=[\\s)\\]},;(]|$)"
        },
        {
          "comment": "Collection, array, sequence functions",
          "name": "entity.name.function.dvala",
          "match": "(?<=[\\s(\\[{,;]|^)(?:filter|map|reduce|get|count|contains|assoc|range|repeat|flatten|nth|first|last|pop|indexOf|push|rest|next|reverse|second|slice|some|sort|take|takeLast|drop|dropLast|takeWhile|dropWhile)(?=[\\s)\\]},;(]|$)"
        },
        {
          "comment": "Math functions",
          "name": "entity.name.function.dvala",
          "match": "(?<=[\\s(\\[{,;]|^)(?:inc|dec|quot|mod|sqrt|cbrt|round|trunc|floor|ceil|min|max|abs|sign)(?=[\\s)\\]},;(]|$)"
        },
        {
          "comment": "String, regexp, misc functions",
          "name": "entity.name.function.dvala",
          "match": "(?<=[\\s(\\[{,;]|^)(?:str|number|lowerCase|upperCase|trim|join|split|regexp|reMatch|replace|replaceAll|not|boolean|compare|typeOf|doc|arity|effectName|effectMatcher)(?=[\\s)\\]},;(]|$)"
        },
        {
          "comment": "Object functions",
          "name": "entity.name.function.dvala",
          "match": "(?<=[\\s(\\[{,;]|^)(?:keys|vals|entries|find|dissoc|merge|mergeWith|zipmap|selectKeys)(?=[\\s)\\]},;(]|$)"
        },
        {
          "comment": "Functional",
          "name": "entity.name.function.dvala",
          "match": "(?<=[\\s(\\[{,;]|^)(?:apply|identity|comp|constantly)(?=[\\s)\\]},;(]|$)"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.control.dvala",
          "match": "->"
        },
        {
          "name": "keyword.operator.pipe.dvala",
          "match": "\\|\\|>|\\|>"
        },
        {
          "name": "keyword.operator.spread.dvala",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.comparison.dvala",
          "match": "==|!=|>=|<=|[≤≥]|(?<![a-zA-Z])[<>](?![a-zA-Z])"
        },
        {
          "name": "keyword.operator.logical.dvala",
          "match": "&&|\\|\\||\\?\\?"
        },
        {
          "name": "keyword.operator.arithmetic.dvala",
          "match": "[+*/%^-]|\\+\\+"
        },
        {
          "name": "keyword.operator.bitwise.dvala",
          "match": "<<|>>>|>>|&|\\||(?<=[\\s(\\[{,;]|^)xor(?=[\\s)\\]},;]|$)"
        },
        {
          "name": "keyword.operator.assignment.dvala",
          "match": "="
        },
        {
          "name": "keyword.operator.accessor.dvala",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.dvala",
          "match": "[,;:]"
        }
      ]
    },
    "brackets": {
      "patterns": [
        {
          "name": "punctuation.paren.open.dvala",
          "match": "\\("
        },
        {
          "name": "punctuation.paren.close.dvala",
          "match": "\\)"
        },
        {
          "name": "punctuation.bracket.open.dvala",
          "match": "\\["
        },
        {
          "name": "punctuation.bracket.close.dvala",
          "match": "\\]"
        },
        {
          "name": "punctuation.brace.open.dvala",
          "match": "\\{"
        },
        {
          "name": "punctuation.brace.close.dvala",
          "match": "\\}"
        }
      ]
    },
    "symbols": {
      "patterns": [
        {
          "comment": "Regular identifiers (JS-style: letters, digits, _, $)",
          "name": "variable.other.dvala",
          "match": "[a-zA-Z_$][a-zA-Z0-9_$]*"
        }
      ]
    }
  }
}
