let robotify = (input) -> do
  let words = split(input, " ");

  let stutter = (word) -> do
    let c = upperCase(word[0]);
    str(c, "-", c, "-", upperCase(word));
  end;

  let stuttered = map(words, stutter);

  ">>> INITIATING TRANSMISSION... " ++ join(stuttered, "... ") ++
    "... BEEP BOOP. END TRANSMISSION <<<";
end;

let input = perform(@dvala.io.read, "Enter a message: ");
robotify(input);
