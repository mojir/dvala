let robotify = (input) -> do
  let words = split(input, " ");

  let stutter = (word) -> do
    let c = upper-case(word[0]);
    str(c, "-", c, "-", upper-case(word))
  end;

  let stuttered = map(words, stutter);

  ">>> INITIATING TRANSMISSION... " ++ join(stuttered, "... ") ++ "... BEEP BOOP. END TRANSMISSION <<<"
end;

let input = perform(@dvala.io.read-line, "Enter a message: ");
robotify(input)
