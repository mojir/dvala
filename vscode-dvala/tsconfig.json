{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "commonjs",
    "strict": true,
    "outDir": "out",
    "sourceMap": true,
    "skipLibCheck": true,
    "typeRoots": ["../node_modules/@types", "../types"],
    "paths": {
      "@mojir/dvala": ["../src/index.ts"],
      "@mojir/dvala/bundler": ["../src/bundler.ts"],
      "@mojir/dvala/tooling": ["../src/tooling.ts"],
      "@mojir/dvala-runtime": ["../packages/dvala-runtime/src/index.ts"],
      "@mojir/dvala-types": ["../packages/dvala-types/src/index.ts"],
      "@mojir/dvala-engine": ["../packages/dvala-engine/src/index.ts"],
      "@mojir/dvala-core-tooling": ["../packages/dvala-core-tooling/src/index.ts"],
      "@mojir/dvala-workspace-backend": ["../packages/dvala-workspace-backend/src/index.ts"],
      "@mojir/dvala-workspace-backend/runtime": ["../packages/dvala-workspace-backend/src/runtime/index.ts"],
      "@mojir/dvala-workspace-backend/adapters/playground-worker-protocol": [
        "../packages/dvala-workspace-backend/src/adapters/playgroundWorkerProtocol.ts"
      ]
    }
  },
  "references": [{ "path": "../packages/dvala-runtime" }],
  "include": ["src", "../types"],
  "exclude": ["node_modules", ".vscode-test"]
}
