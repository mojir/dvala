{
  "name": "dvala-monorepo",
  "version": "0.4.2",
  "private": true,
  "engines": {
    "node": ">=26 <27"
  },
  "description": "Monorepo root for Dvala — a suspendable, time-traveling functional language for JavaScript with algebraic effects. Sub-packages live under packages/* and apps/*; this root no longer ships an importable package.",
  "author": "Albert Mojir",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mojir/dvala.git"
  },
  "keywords": [
    "dvala",
    "functional",
    "programming-language",
    "interpreter",
    "suspendable",
    "resumable",
    "algebraic-effects",
    "time-travel",
    "pure",
    "immutable",
    "expression-language",
    "typescript",
    "javascript",
    "lisp",
    "clojure"
  ],
  "scripts": {
    "preinstall": "npx -y only-allow pnpm",
    "test": "turbo run build && vitest run",
    "test:coverage": "turbo run build && vitest run --coverage",
    "test:changed": "vitest run --changed",
    "vitest": "vitest",
    "lint": "turbo run build --filter=@mojir/dvala-engine --filter=@mojir/dvala-core-tooling && oxfmt --ignore-path=.oxfmtignore . && oxlint --fix .",
    "lint:no-fix": "turbo run build --filter=@mojir/dvala-engine --filter=@mojir/dvala-core-tooling && oxfmt --ignore-path=.oxfmtignore --check . && oxlint .",
    "typecheck": "turbo run build && tsgo -p ./tsconfig.compile.json --noEmit && tsgo -p vscode-dvala/tsconfig.json --noEmit",
    "typecheck:watch": "turbo run build && tsgo -p ./tsconfig.compile.json --noEmit --watch",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run knip && pnpm run build && pnpm run test",
    "check:no-fix": "pnpm run lint:no-fix && pnpm run typecheck && pnpm run knip && pnpm run test",
    "clean": "pnpm run clean-dvala && rm -rf docs/* .turbo .wireit coverage test-results vscode-dvala/out .cache",
    "clean-dvala": "rm -rf dist build packages/dvala-runtime/dist packages/dvala-workspace-backend/dist packages/dvala-mcp-server/dist packages/dvala-core-tooling/dist packages/dvala-cli/dist packages/dvala-test-framework/dist packages/dvala-types/dist packages/dvala-engine/dist apps/playground-www/dist apps/playground-www/build apps/playground-builder/dist",
    "build": "turbo run bundle",
    "build-book": "pnpm run build && node scripts/generate-pdf.mjs",
    "dvala": "pnpm --filter @mojir/dvala-cli start",
    "benchmarks:pds": "rolldown -c rolldown.config.benchmarks.mjs && node benchmarks/build/pds-baseline.cjs",
    "benchmarks:run": "rolldown -c rolldown.config.benchmarks.mjs && node benchmarks/build/pipeline-baseline.cjs",
    "install-hooks": "git config core.hooksPath .githooks && echo 'git hooks installed: core.hooksPath=.githooks'",
    "uninstall-hooks": "git config --unset core.hooksPath && echo 'git hooks uninstalled: core.hooksPath unset'",
    "demo": "node scripts/demo-link.mjs",
    "format-snippets": "npx tsx scripts/format-sources.ts",
    "pdf": "node scripts/generate-pdf.mjs",
    "dev": "pnpm --filter @mojir/dvala-playground-www dev",
    "dev:prod-preview": "npx serve docs -p 22230 --single",
    "test:e2e": "npx playwright test",
    "test:e2e:prod": "E2E_BASE_URL=https://mojir.github.io/dvala npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:prod:headed": "E2E_BASE_URL=https://mojir.github.io/dvala npx playwright test --headed",
    "lcov": "open-cli ./coverage/index.html",
    "mcp:inspect": "pnpm --filter @mojir/dvala-mcp-server inspect",
    "knip": "knip"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "1.60.0",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260605.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.0",
    "glob": "^13.0.6",
    "happy-dom": "^20.10.1",
    "highlight.js": "^11.11.1",
    "knip": "^6.15.0",
    "monaco-editor": "^0.55.1",
    "open-cli": "^9.0.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "rolldown": "^1.1.0",
    "serve": "^14.2.6",
    "tsx": "^4.22.4",
    "turbo": "^2.9.16",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@mojir/dvala-common": "workspace:*",
    "@mojir/dvala-core-tooling": "workspace:*",
    "@mojir/dvala-engine": "workspace:*",
    "@mojir/dvala-runtime": "workspace:*",
    "@mojir/dvala-test-framework": "workspace:*",
    "@mojir/dvala-types": "workspace:*",
    "@vue/reactivity": "^3.5.33",
    "marked": "^18.0.2"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
