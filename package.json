{
  "name": "@mojir/dvala",
  "version": "0.0.10",
  "description": "dvala",
  "author": "Albert Mojir",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mojir/dvala.git"
  },
  "keywords": [
    "Dvala",
    "Functional",
    "Pure",
    "Typescript",
    "Web",
    "Compiler",
    "AST",
    "Interpreter",
    "Clojure"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./full": {
      "types": "./dist/src/full.d.ts",
      "import": "./dist/full.esm.js",
      "require": "./dist/full.js"
    },
    "./bundler": {
      "types": "./dist/src/bundler.d.ts",
      "import": "./dist/bundler.esm.js",
      "require": "./dist/bundler.js"
    },
    "./modules/assertion": {
      "types": "./dist/src/modules/assertion.d.ts",
      "import": "./dist/modules/assertion.esm.js",
      "require": "./dist/modules/assertion.js"
    },
    "./modules/grid": {
      "types": "./dist/src/modules/grid.d.ts",
      "import": "./dist/modules/grid.esm.js",
      "require": "./dist/modules/grid.js"
    },
    "./modules/vector": {
      "types": "./dist/src/modules/vector.d.ts",
      "import": "./dist/modules/vector.esm.js",
      "require": "./dist/modules/vector.js"
    },
    "./modules/linear-algebra": {
      "types": "./dist/src/modules/linear-algebra.d.ts",
      "import": "./dist/modules/linear-algebra.esm.js",
      "require": "./dist/modules/linear-algebra.js"
    },
    "./modules/matrix": {
      "types": "./dist/src/modules/matrix.d.ts",
      "import": "./dist/modules/matrix.esm.js",
      "require": "./dist/modules/matrix.js"
    },
    "./modules/number-theory": {
      "types": "./dist/src/modules/number-theory.d.ts",
      "import": "./dist/modules/number-theory.esm.js",
      "require": "./dist/modules/number-theory.js"
    },
    "./modules/math": {
      "types": "./dist/src/modules/math.d.ts",
      "import": "./dist/modules/math.esm.js",
      "require": "./dist/modules/math.js"
    },
    "./modules/functional": {
      "types": "./dist/src/modules/functional.d.ts",
      "import": "./dist/modules/functional.esm.js",
      "require": "./dist/modules/functional.js"
    },
    "./modules/string": {
      "types": "./dist/src/modules/string.d.ts",
      "import": "./dist/modules/string.esm.js",
      "require": "./dist/modules/string.js"
    },
    "./modules/collection": {
      "types": "./dist/src/modules/collection.d.ts",
      "import": "./dist/modules/collection.esm.js",
      "require": "./dist/modules/collection.js"
    },
    "./modules/sequence": {
      "types": "./dist/src/modules/sequence.d.ts",
      "import": "./dist/modules/sequence.esm.js",
      "require": "./dist/modules/sequence.js"
    },
    "./modules/bitwise": {
      "types": "./dist/src/modules/bitwise.d.ts",
      "import": "./dist/modules/bitwise.esm.js",
      "require": "./dist/modules/bitwise.js"
    },
    "./modules/convert": {
      "types": "./dist/src/modules/convert.d.ts",
      "import": "./dist/modules/convert.esm.js",
      "require": "./dist/modules/convert.js"
    },
    "./debug": {
      "types": "./dist/src/debug.d.ts",
      "import": "./dist/debug.esm.js",
      "require": "./dist/debug.js"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "iife": "dist/dvala.iife.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "dvala": "dist/cli/cli.js",
    "dvala-mcp": "dist/mcp-server/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "wireit",
    "vitest": "vitest",
    "lint": "wireit",
    "lint:no-fix": "wireit",
    "typecheck": "wireit",
    "typecheck:watch": "tsc -p ./tsconfig.compile.json --noEmit --watch",
    "check": "npm install && npm run lint && npm run typecheck && npm run test && npm run build",
    "check:no-fix": "npm run lint:no-fix && npm run typecheck && npm run test",
    "clean": "npm run clean-dvala && npm run clean-playground && rm -rf .wireit coverage test-results vscode-dvala/out",
    "clean-dvala": "rm -rf dist build",
    "clean-playground": "rm -rf playground-builder/build playground-www/build",
    "build": "wireit",
    "build-dvala": "wireit",
    "build-cli": "wireit",
    "build-mcp": "wireit",
    "build-playground": "wireit",
    "build-vscode-ext": "wireit",
    "dvala": "node ./dist/cli/cli.js",
    "dev": "npx serve docs -p 9901",
    "test:e2e": "npx playwright test",
    "lcov": "open-cli ./coverage/index.html",
    "mcp:inspect": "npx @modelcontextprotocol/inspector node ./dist/mcp-server/server.js"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.0",
    "@eslint/js": "^10.0.1",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.3.5",
    "@types/vscode": "^1.109.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "open-cli": "8.0.0",
    "rollup": "^4.59.0",
    "serve": "^14.2.6",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18",
    "wireit": "^0.14.12",
    "zod": "^4.3.6"
  },
  "wireit": {
    "lint": {
      "command": "eslint . --fix",
      "files": [
        "src/**/*.ts",
        "common/**/*.ts",
        "cli/src/**/*.ts",
        "mcp-server/src/**/*.ts",
        "playground-builder/src/**/*.ts",
        "playground-www/src/**/*.ts",
        "reference/**/*.ts",
        "__tests__/**/*.ts",
        "vscode-dvala/src/**/*.ts",
        "eslint.config.js"
      ],
      "output": []
    },
    "lint:no-fix": {
      "command": "eslint .",
      "files": [
        "src/**/*.ts",
        "common/**/*.ts",
        "cli/src/**/*.ts",
        "mcp-server/src/**/*.ts",
        "playground-builder/src/**/*.ts",
        "playground-www/src/**/*.ts",
        "reference/**/*.ts",
        "__tests__/**/*.ts",
        "vscode-dvala/src/**/*.ts",
        "eslint.config.js"
      ],
      "output": []
    },
    "typecheck": {
      "command": "tsc -p ./tsconfig.compile.json --noEmit && tsc -p vscode-dvala/tsconfig.json --noEmit",
      "files": [
        "src/**/*.ts",
        "common/**/*.ts",
        "cli/src/**/*.ts",
        "mcp-server/src/**/*.ts",
        "playground-builder/src/**/*.ts",
        "playground-www/src/**/*.ts",
        "reference/**/*.ts",
        "types/**/*.ts",
        "vscode-dvala/src/**/*.ts",
        "tsconfig*.json",
        "vscode-dvala/tsconfig.json"
      ],
      "output": []
    },
    "test": {
      "command": "vitest run --coverage",
      "files": [
        "src/**",
        "common/**",
        "__tests__/**",
        "reference/**",
        "vitest.setup.ts",
        "vite.config.mts",
        "tsconfig.json"
      ],
      "output": [
        "coverage/**"
      ]
    },
    "build": {
      "dependencies": [
        "build-dvala",
        "build-cli",
        "build-mcp",
        "build-playground",
        "build-vscode-ext"
      ]
    },
    "build-dvala": {
      "command": "rollup -c",
      "files": [
        "src/**",
        "common/**",
        "reference/**/*.ts",
        "rollup.config.js",
        "rollup.plugins.js",
        "tsconfig.json",
        "package.json"
      ],
      "output": [
        "dist/**",
        "!dist/cli/**",
        "!dist/mcp-server/**"
      ],
      "clean": "if-file-deleted"
    },
    "build-cli": {
      "command": "rollup -c rollup.config.cli.js",
      "files": [
        "cli/src/**",
        "src/**",
        "common/**",
        "rollup.config.cli.js",
        "rollup.plugins.js",
        "tsconfig.cli.json"
      ],
      "output": [
        "dist/cli/**"
      ],
      "clean": "if-file-deleted"
    },
    "build-mcp": {
      "command": "rollup -c rollup.config.mcp-server.js",
      "files": [
        "mcp-server/src/**",
        "src/**",
        "common/**",
        "rollup.config.mcp-server.js",
        "rollup.plugins.js",
        "tsconfig.mcp-server.json"
      ],
      "output": [
        "dist/mcp-server/**"
      ],
      "clean": "if-file-deleted"
    },
    "build-playground": {
      "command": "rollup -c rollup.config.playground-builder.js && rollup -c rollup.config.playground-www.js && node ./playground-builder/build/buildPlaygroundSite.js",
      "files": [
        "playground-builder/src/**",
        "playground-www/src/**",
        "playground-www/public/**",
        "src/**",
        "common/**",
        "reference/**/*.ts",
        "rollup.config.playground-builder.js",
        "rollup.config.playground-www.js",
        "rollup.plugins.js",
        "tsconfig.playground-builder.json",
        "tsconfig.playground-www.json"
      ],
      "output": [
        "playground-builder/build/**",
        "playground-www/build/**",
        "docs/playground.js",
        "docs/index.html",
        "docs/styles.css"
      ],
      "clean": "if-file-deleted"
    },
    "build-vscode-ext": {
      "command": "node vscode-dvala/build.mjs",
      "files": [
        "vscode-dvala/src/**",
        "vscode-dvala/package.json",
        "vscode-dvala/build.mjs",
        "src/**",
        "common/**",
        "package.json"
      ],
      "output": [
        "vscode-dvala/out/**"
      ],
      "clean": "if-file-deleted"
    }
  }
}
