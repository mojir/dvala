{
  "name": "dvala-monorepo",
  "version": "0.4.2",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "pnpm": {
    "overrides": {
      "file-type": "^21.3.2"
    },
    "onlyBuiltDependencies": [
      "@vscode/vsce-sign",
      "esbuild",
      "keytar"
    ]
  },
  "description": "Monorepo root for Dvala — a suspendable, time-traveling functional language for JavaScript with algebraic effects. Sub-packages live under packages/* and apps/*; this root no longer ships an importable package.",
  "author": "Albert Mojir",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mojir/dvala.git"
  },
  "keywords": [
    "dvala",
    "functional",
    "programming-language",
    "interpreter",
    "suspendable",
    "resumable",
    "algebraic-effects",
    "time-travel",
    "pure",
    "immutable",
    "expression-language",
    "typescript",
    "javascript",
    "lisp",
    "clojure"
  ],
  "scripts": {
    "preinstall": "npx -y only-allow pnpm",
    "test": "wireit",
    "test:coverage": "wireit",
    "test:changed": "vitest run --changed",
    "vitest": "vitest",
    "lint": "wireit",
    "lint:no-fix": "wireit",
    "typecheck": "wireit",
    "typecheck:watch": "pnpm --filter @mojir/dvala-runtime run build && tsgo -p ./tsconfig.compile.json --noEmit --watch",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run knip && pnpm run build && pnpm run test",
    "check:no-fix": "pnpm run lint:no-fix && pnpm run typecheck && pnpm run knip && pnpm run test",
    "clean": "pnpm run clean-dvala && pnpm run clean-playground && rm -rf .wireit coverage test-results vscode-dvala/out .cache",
    "clean-dvala": "rm -rf dist build packages/dvala-runtime/dist packages/dvala-workspace-backend/dist packages/dvala-mcp-server/dist packages/dvala-core-tooling/dist packages/dvala-cli/dist apps/playground-www/dist",
    "clean-playground": "rm -rf playground-builder/build apps/playground-www/build",
    "build": "wireit",
    "build-cli": "wireit",
    "build-mcp": "wireit",
    "build-playground-www": "wireit",
    "build-playground": "wireit",
    "build-book": "wireit",
    "build-vscode-ext": "wireit",
    "dvala": "node ./dist/cli/cli.js",
    "benchmarks:pds": "rolldown -c rolldown.config.benchmarks.mjs && node benchmarks/build/pds-baseline.cjs",
    "benchmarks:run": "rolldown -c rolldown.config.benchmarks.mjs && node benchmarks/build/pipeline-baseline.cjs",
    "install-hooks": "git config core.hooksPath .githooks && echo 'git hooks installed: core.hooksPath=.githooks'",
    "uninstall-hooks": "git config --unset core.hooksPath && echo 'git hooks uninstalled: core.hooksPath unset'",
    "demo": "node scripts/demo-link.mjs",
    "format-snippets": "npx tsx scripts/format-sources.ts",
    "pdf": "node scripts/generate-pdf.mjs",
    "dev": "vite --config apps/playground-www/vite.config.mjs",
    "dev:prod-preview": "npx serve docs -p 22230 --single",
    "test:e2e": "npx playwright test",
    "test:e2e:prod": "E2E_BASE_URL=https://mojir.github.io/dvala npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:prod:headed": "E2E_BASE_URL=https://mojir.github.io/dvala npx playwright test --headed",
    "lcov": "open-cli ./coverage/index.html",
    "mcp:inspect": "npx @modelcontextprotocol/inspector node ./dist/mcp-server/server.js",
    "knip": "wireit"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@playwright/test": "1.59.1",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "@vitest/coverage-v8": "^4.1.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.28.0",
    "glob": "^13.0.6",
    "happy-dom": "^20.9.0",
    "highlight.js": "^11.11.1",
    "knip": "^6.7.0",
    "monaco-editor": "^0.55.1",
    "open-cli": "^9.0.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.0",
    "rolldown": "^1.0.0-rc.9",
    "serve": "^14.2.6",
    "tsx": "^4.21.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.0",
    "wireit": "^0.14.12",
    "zod": "^4.3.6"
  },
  "wireit": {
    "lint": {
      "command": "pnpm --filter @mojir/dvala-engine run build && pnpm --filter @mojir/dvala-core-tooling run build && oxfmt . && oxlint --fix .",
      "files": [
        "packages/dvala-runtime/src/**/*.ts",
        "packages/dvala-runtime/package.json",
        "packages/dvala-runtime/tsconfig.json",
        "packages/dvala-mcp-server/src/**/*.ts",
        "packages/dvala-mcp-server/package.json",
        "packages/dvala-mcp-server/tsconfig.json",
        "packages/dvala-core-tooling/src/**/*.ts",
        "packages/dvala-core-tooling/package.json",
        "packages/dvala-core-tooling/tsconfig.json",
        "packages/dvala-engine/src/**/*.ts",
        "packages/dvala-engine/package.json",
        "packages/dvala-engine/tsconfig.json",
        "packages/dvala-cli/src/**/*.ts",
        "packages/dvala-cli/package.json",
        "packages/dvala-cli/tsconfig.json",
        "packages/dvala-workspace-backend/src/**/*.ts",
        "packages/dvala-workspace-backend/package.json",
        "packages/dvala-workspace-backend/tsconfig.json",
        "apps/playground-www/src/**/*.ts",
        "apps/playground-www/package.json",
        "apps/playground-www/tsconfig.json",
        "common/**/*.ts",
        "cli/src/**/*.ts",
        "mcp-server/src/**/*.ts",
        "playground-builder/src/**/*.ts",
        "apps/playground-www/src/**/*.ts",
        "reference/**/*.ts",
        "__tests__/**/*.ts",
        ".oxlintrc.json",
        ".oxfmtrc.json",
        ".prettierignore",
        "!**/node_modules/**"
      ],
      "output": []
    },
    "lint:no-fix": {
      "command": "pnpm --filter @mojir/dvala-engine run build && pnpm --filter @mojir/dvala-core-tooling run build && oxfmt --check . && oxlint .",
      "files": [
        "packages/dvala-runtime/src/**/*.ts",
        "packages/dvala-runtime/package.json",
        "packages/dvala-runtime/tsconfig.json",
        "packages/dvala-mcp-server/src/**/*.ts",
        "packages/dvala-mcp-server/package.json",
        "packages/dvala-mcp-server/tsconfig.json",
        "packages/dvala-core-tooling/src/**/*.ts",
        "packages/dvala-core-tooling/package.json",
        "packages/dvala-core-tooling/tsconfig.json",
        "packages/dvala-engine/src/**/*.ts",
        "packages/dvala-engine/package.json",
        "packages/dvala-engine/tsconfig.json",
        "packages/dvala-cli/src/**/*.ts",
        "packages/dvala-cli/package.json",
        "packages/dvala-cli/tsconfig.json",
        "packages/dvala-workspace-backend/src/**/*.ts",
        "packages/dvala-workspace-backend/package.json",
        "packages/dvala-workspace-backend/tsconfig.json",
        "apps/playground-www/src/**/*.ts",
        "apps/playground-www/package.json",
        "apps/playground-www/tsconfig.json",
        "common/**/*.ts",
        "cli/src/**/*.ts",
        "mcp-server/src/**/*.ts",
        "playground-builder/src/**/*.ts",
        "apps/playground-www/src/**/*.ts",
        "reference/**/*.ts",
        "__tests__/**/*.ts",
        ".oxlintrc.json",
        ".oxfmtrc.json",
        ".prettierignore",
        "!**/node_modules/**"
      ],
      "output": []
    },
    "knip": {
      "command": "knip",
      "files": [
        "packages/dvala-runtime/src/**/*.ts",
        "packages/dvala-runtime/package.json",
        "packages/dvala-mcp-server/src/**/*.ts",
        "packages/dvala-mcp-server/package.json",
        "packages/dvala-core-tooling/src/**/*.ts",
        "packages/dvala-core-tooling/package.json",
        "packages/dvala-cli/src/**/*.ts",
        "packages/dvala-cli/package.json",
        "packages/dvala-workspace-backend/src/**/*.ts",
        "packages/dvala-workspace-backend/package.json",
        "apps/playground-www/src/**/*.ts",
        "apps/playground-www/package.json",
        "common/**/*.ts",
        "cli/src/**/*.ts",
        "mcp-server/src/**/*.ts",
        "playground-builder/src/**/*.ts",
        "apps/playground-www/src/**/*.ts",
        "reference/**/*.ts",
        "__tests__/**/*.ts",
        "vscode-dvala/src/**/*.ts",
        "benchmarks/*.ts",
        "scripts/**/*.{ts,mjs}",
        "knip.json",
        "package.json",
        "tsconfig*.json",
        "!**/node_modules/**"
      ],
      "output": []
    },
    "typecheck": {
      "command": "pnpm --filter @mojir/dvala-runtime run build && pnpm --filter @mojir/dvala-engine run build && tsgo -p ./tsconfig.compile.json --noEmit && tsgo -p vscode-dvala/tsconfig.json --noEmit",
      "files": [
        "packages/dvala-runtime/src/**/*.ts",
        "packages/dvala-runtime/package.json",
        "packages/dvala-runtime/tsconfig.json",
        "packages/dvala-mcp-server/src/**/*.ts",
        "packages/dvala-mcp-server/package.json",
        "packages/dvala-mcp-server/tsconfig.json",
        "packages/dvala-core-tooling/src/**/*.ts",
        "packages/dvala-core-tooling/package.json",
        "packages/dvala-core-tooling/tsconfig.json",
        "packages/dvala-engine/src/**/*.ts",
        "packages/dvala-engine/package.json",
        "packages/dvala-engine/tsconfig.json",
        "packages/dvala-cli/src/**/*.ts",
        "packages/dvala-cli/package.json",
        "packages/dvala-cli/tsconfig.json",
        "packages/dvala-workspace-backend/src/**/*.ts",
        "packages/dvala-workspace-backend/package.json",
        "packages/dvala-workspace-backend/tsconfig.json",
        "apps/playground-www/src/**/*.ts",
        "apps/playground-www/package.json",
        "apps/playground-www/tsconfig.json",
        "common/**/*.ts",
        "cli/src/**/*.ts",
        "mcp-server/src/**/*.ts",
        "playground-builder/src/**/*.ts",
        "apps/playground-www/src/**/*.ts",
        "reference/**/*.ts",
        "types/**/*.ts",
        "vscode-dvala/src/**/*.ts",
        "tsconfig*.json",
        "vscode-dvala/tsconfig.json",
        "!**/node_modules/**"
      ],
      "output": [
        "packages/dvala-runtime/dist/**"
      ]
    },
    "test": {
      "command": "vitest run",
      "files": [
        "packages/dvala-runtime/src/**",
        "packages/dvala-workspace-backend/src/**",
        "common/**",
        "__tests__/**",
        "reference/**",
        "vitest.setup.ts",
        "vite.config.mts",
        "tsconfig.json",
        "!**/node_modules/**"
      ],
      "output": []
    },
    "test:coverage": {
      "command": "vitest run --coverage",
      "files": [
        "packages/dvala-runtime/src/**",
        "packages/dvala-workspace-backend/src/**",
        "common/**",
        "__tests__/**",
        "reference/**",
        "vitest.setup.ts",
        "vite.config.mts",
        "tsconfig.json",
        "!**/node_modules/**"
      ],
      "output": [
        "coverage/**"
      ]
    },
    "build": {
      "dependencies": [
        "build-cli",
        "build-mcp",
        "build-playground-www",
        "build-playground",
        "build-vscode-ext"
      ]
    },
    "build-cli": {
      "command": "rolldown -c rolldown.config.cli.mjs && chmod +x dist/cli/cli.js",
      "files": [
        "packages/dvala-cli/src/**",
        "packages/dvala-cli/package.json",
        "packages/dvala-cli/tsconfig.json",
        "cli/src/**",
        "common/**",
        "rolldown.config.cli.mjs",
        "rolldown.plugins.mjs",
        "tsconfig.cli.json"
      ],
      "output": [
        "dist/cli/**"
      ],
      "clean": "if-file-deleted"
    },
    "build-mcp": {
      "command": "rolldown -c rolldown.config.mcp-server.mjs && chmod +x dist/mcp-server/server.js",
      "files": [
        "packages/dvala-mcp-server/src/**",
        "packages/dvala-mcp-server/package.json",
        "packages/dvala-mcp-server/tsconfig.json",
        "mcp-server/src/**",
        "common/**",
        "rolldown.config.mcp-server.mjs",
        "rolldown.plugins.mjs",
        "tsconfig.mcp-server.json"
      ],
      "output": [
        "dist/mcp-server/**"
      ],
      "clean": "if-file-deleted"
    },
    "build-playground-www": {
      "command": "pnpm --filter @mojir/dvala-playground-www run build",
      "files": [
        "apps/playground-www/src/**",
        "apps/playground-www/package.json",
        "apps/playground-www/tsconfig.json"
      ],
      "output": [
        "apps/playground-www/dist/**"
      ],
      "clean": "if-file-deleted"
    },
    "build-playground": {
      "command": "rolldown -c rolldown.config.playground-builder.mjs && rolldown -c rolldown.config.playground-www.mjs && node ./playground-builder/build/buildPlaygroundSite.js",
      "files": [
        "playground-builder/src/**",
        "apps/playground-www/src/**",
        "apps/playground-www/public/**",
        "common/**",
        "reference/**/*.ts",
        "book/**",
        "rolldown.config.playground-builder.mjs",
        "rolldown.config.playground-www.mjs",
        "rolldown.plugins.mjs",
        "tsconfig.playground-builder.json",
        "tsconfig.playground-www.json"
      ],
      "output": [
        "playground-builder/build/**",
        "apps/playground-www/build/**",
        "docs/**"
      ],
      "clean": "if-file-deleted"
    },
    "build-book": {
      "command": "node scripts/generate-pdf.mjs",
      "dependencies": [
        "build-playground"
      ],
      "files": [
        "scripts/generate-pdf.mjs",
        "book/**"
      ],
      "output": [
        "docs/the-dvala-book.pdf"
      ],
      "clean": "if-file-deleted"
    },
    "build-vscode-ext": {
      "command": "node vscode-dvala/build.mjs",
      "files": [
        "vscode-dvala/src/**",
        "vscode-dvala/package.json",
        "vscode-dvala/build.mjs",
        "common/**",
        "package.json"
      ],
      "output": [
        "vscode-dvala/out/**"
      ],
      "clean": "if-file-deleted"
    }
  },
  "dependencies": {
    "@mojir/dvala-core-tooling": "workspace:*",
    "@mojir/dvala-engine": "workspace:*",
    "@mojir/dvala-runtime": "workspace:*",
    "@mojir/dvala-test-framework": "workspace:*",
    "@mojir/dvala-types": "workspace:*",
    "@vue/reactivity": "^3.5.33",
    "marked": "^18.0.2"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
