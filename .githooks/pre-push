#!/usr/bin/env bash
#
# Pre-push hook: runs the Dvala pipeline perf benchmark before pushing
# any commit that touches source code, so the perf history stays dense
# without depending on memory.
#
# Behavior:
#   1. For each ref being pushed, find commits in (remote..local) that
#      touch any source file under `src/`.
#   2. If any such commit exists AND HEAD's short hash is not yet in
#      benchmarks/pipeline-history.json, run `pnpm run benchmarks:run`,
#      abort the push, and tell the user to commit the bench data.
#   3. If the data already exists for HEAD, push proceeds.
#   4. If no source code was touched, push proceeds.
#
# Override with `git push --no-verify` for non-perf-relevant force-pushes
# or when bench output is unwanted.
#
# Installed by `pnpm run install-hooks` (sets core.hooksPath=.githooks).

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Files that, when changed, demand a fresh perf row. Anything under
# `src/` plausibly affects pipeline timing — broader is safer than
# missing a regression. Use `--no-verify` for non-perf-relevant pushes.
SOURCE_PATHS=(
  'src/'
)

HISTORY_FILE='benchmarks/pipeline-history.json'
ZERO='0000000000000000000000000000000000000000'

# Determine the default base branch (origin/main) for new-branch pushes.
DEFAULT_BASE='origin/main'

# Collect the LATEST src/-touching commit per ref — that commit is
# the subject of the bench (the one whose hash gets recorded). Using
# the ref tip would mean a follow-up "bench data" commit (which itself
# doesn't touch src/) moves the tip to a SHA that has no bench row,
# and the hook would loop forever asking for more data.
#
# Stored as space-separated full SHAs in `bench_tips`.
bench_tips=''

while read -r local_ref local_sha remote_ref remote_sha; do
  # Branch deletion — nothing to bench.
  if [[ "$local_sha" == "$ZERO" ]]; then
    continue
  fi

  # New branch — diff against the default base instead of an empty SHA,
  # otherwise `git log` would walk the entire history.
  if [[ "$remote_sha" == "$ZERO" ]]; then
    if git rev-parse --verify --quiet "$DEFAULT_BASE" >/dev/null; then
      range="$DEFAULT_BASE..$local_sha"
    else
      # No upstream main known — only check the tip commit.
      range="$local_sha~1..$local_sha"
    fi
  else
    range="$remote_sha..$local_sha"
  fi

  # Latest commit in the range that touched source code. `git log`
  # returns commits newest-first; `head -n 1` picks the most recent.
  # Empty output means no commit in the range touched src/.
  latest_src_touch="$(git log "$range" --pretty=format:%H -- "${SOURCE_PATHS[@]}" 2>/dev/null | head -n 1)"
  if [[ -n "$latest_src_touch" ]]; then
    bench_tips="$bench_tips $latest_src_touch"
  fi
done

if [[ -z "$bench_tips" ]]; then
  exit 0
fi

# Walk collected src/-touching commits, partition into "have data" /
# "missing data". A missing commit blocks the push. The bench can only
# be run for HEAD (it rev-parses HEAD internally to tag the row), so:
#   - if HEAD is the unique missing commit → bench HEAD, abort, ask to commit
#   - if some other commit is missing → user must rebase / push that
#     commit so it becomes HEAD when its bench runs
missing_commits=''
head_sha="$(git rev-parse HEAD)"
head_short="$(git rev-parse --short HEAD)"
for commit in $bench_tips; do
  short="$(git rev-parse --short "$commit")"
  if [[ -f "$HISTORY_FILE" ]] && grep -q "\"commit\": \"$short\"" "$HISTORY_FILE"; then
    echo "✓ pipeline perf data already recorded for $short"
  else
    missing_commits="$missing_commits $commit"
  fi
done

if [[ -z "$missing_commits" ]]; then
  echo "✓ all src/-touching commits in this push have perf data — push proceeding"
  exit 0
fi

# Bench tags rows with HEAD's hash. If the missing src/-touching
# commit isn't HEAD, we can't bench it without checking it out (which
# would clobber the user's working state). Refuse and tell them what
# to do.
head_in_missing=0
for commit in $missing_commits; do
  [[ "$commit" == "$head_sha" ]] && head_in_missing=1
done

if [[ "$head_in_missing" -eq 0 ]]; then
  echo "❌ Push has src/-touching commits with no perf data, but none are HEAD."
  echo "   The bench tags rows with HEAD's hash, so the target commit must be HEAD."
  echo "   Rebase to make it HEAD, or skip with --no-verify:"
  for commit in $missing_commits; do
    short="$(git rev-parse --short "$commit")"
    echo "     • $short"
  done
  exit 1
fi

short_sha="$head_short"

# Refuse to bench a dirty tree: the JSON would be tagged with HEAD's
# hash but measure working-tree state. Force the user to clean up first.
if ! git diff --quiet HEAD || ! git diff --cached --quiet; then
  echo "❌ working tree has uncommitted changes."
  echo "   Refusing to benchmark — the recorded data would not match commit $short_sha."
  echo "   Either commit/stash, or push with --no-verify to skip."
  exit 1
fi

cat <<EOF
⏱  Source code touched in this push and no perf data exists for $short_sha.
   Running \`pnpm run benchmarks:run\` (this can take ~30s)...
EOF

if ! pnpm run benchmarks:run >/dev/null 2>&1; then
  echo "❌ benchmark run failed — see \`pnpm run benchmarks:run\` output. Push aborted."
  exit 1
fi

cat <<EOF

✓ Benchmark data appended for $short_sha. Files changed:
   benchmarks/pipeline-history.json
   benchmarks/pipeline-performance.md
   benchmarks/results/pipeline-*.json

Commit them and re-push:

   git add benchmarks/
   git commit -m "bench: $short_sha"
   git push

(Or push with --no-verify to skip bench enforcement entirely.)
EOF
exit 1
