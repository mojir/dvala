{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "cli/src/cli.ts",
        "mcp-server/src/server.ts",
        "playground-builder/src/buildPlaygroundSite.ts",
        "playground-www/src/playground.ts",
        "scripts/*.{ts,mjs}",
        "benchmarks/*.ts",
        "__tests__/**/*.test.ts",
        "src/**/*.test.ts",
        "e2e/**/*.spec.ts"
      ],
      "project": [
        "src/**/*.ts",
        "common/**/*.ts",
        "cli/src/**/*.ts",
        "mcp-server/src/**/*.ts",
        "playground-builder/src/**/*.ts",
        "playground-www/src/**/*.ts",
        "reference/**/*.ts",
        "__tests__/**/*.ts",
        "benchmarks/**/*.ts",
        "scripts/**/*.{ts,mjs}"
      ],
      "ignoreDependencies": ["@vscode/vsce", "serve"]
    },
    "vscode-dvala": {
      "entry": ["src/debugAdapter.ts"],
      "project": ["src/**/*.ts"]
    }
  }
}
