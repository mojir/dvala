{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreIssues": {
    "packages/dvala-runtime/src/types/run.ts": ["types"]
  },
  "workspaces": {
    ".": {
      "entry": [
        "reference/**/*.ts",
        "common/**/*.ts",
        "scripts/*.{ts,mjs}",
        "benchmarks/*.ts",
        "__tests__/**/*.test.ts",
        "e2e/**/*.spec.ts"
      ],
      "project": [
        "common/**/*.ts",
        "reference/**/*.ts",
        "__tests__/**/*.ts",
        "benchmarks/**/*.ts",
        "scripts/**/*.{ts,mjs}"
      ],
      "ignoreDependencies": ["@vscode/vsce", "serve"]
    },
    "apps/playground-builder": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/dvala-types": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/dvala-runtime": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/dvala-engine": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/dvala-workspace-backend": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@mojir/dvala-types"]
    },
    "packages/dvala-mcp-server": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@mojir/dvala-engine", "@mojir/dvala-runtime", "@mojir/dvala-types"]
    },
    "packages/dvala-core-tooling": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/dvala-test-framework": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/dvala-cli": {
      "entry": ["src/index.ts", "src/bin.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/playground-www": {
      "entry": ["src/playground.ts"],
      "project": ["src/**/*.ts"]
    },
    "vscode-dvala": {
      "entry": ["src/extension.ts", "src/debugAdapter.ts"],
      "project": ["src/**/*.ts"]
    }
  }
}
